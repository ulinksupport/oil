# Environment Variables for OIL Tracker

# ─── n8n Webhook URLs ──────────────────────────────────────────────────────────
# URL of your n8n OIL submission webhook (from n8n → Workflow 1 → Webhook node)
N8N_SUBMISSION_WEBHOOK=https://YOUR_N8N_INSTANCE/webhook/oil-submit

# URL of your n8n AI query webhook (from n8n → Workflow 2 → Webhook node)
N8N_QUERY_WEBHOOK=https://YOUR_N8N_INSTANCE/webhook/oil-query

# ─── Server ────────────────────────────────────────────────────────────────────
# Port (Render sets this automatically; leave as 3000 for local dev)
PORT=3000
